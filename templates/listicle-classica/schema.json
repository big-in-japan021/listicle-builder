{
  "name": "listicle-classica",
  "label": "Listicle Clássica (estilo \"10 Reasons Why...\")",
  "description": "Template clássico de listicle de performance / direct response. Hero, N itens numerados, 2 ofertas, timeline de 3 etapas, reviews, footer.",
  "fields": [
    {
      "key": "slug",
      "label": "Slug do projeto (nome curto, sem espaços)",
      "type": "text",
      "default": "nova-listicle",
      "ai_extract": false
    },
    {
      "key": "meta.lang",
      "label": "Idioma da página",
      "type": "text",
      "default": "pt-BR",
      "help": "Ex: pt-BR, es, en",
      "ai_extract": true
    },
    {
      "key": "meta.page_title",
      "label": "Título da aba do navegador",
      "type": "text",
      "ai_extract": true
    },
    {
      "key": "hero",
      "label": "Hero (topo da página)",
      "type": "group",
      "fields": [
        {
          "key": "image",
          "label": "Imagem do topo",
          "type": "image_ai",
          "ai_prompt_key": "hero_image",
          "image_fname": "hero",
          "ai_extract": false
        },
        {
          "key": "stars",
          "label": "Estrelas",
          "type": "text",
          "default": "★★★★★",
          "ai_extract": false
        },
        {
          "key": "social_proof",
          "label": "Prova social",
          "type": "text",
          "placeholder": "+200.000 Clientes Satisfeitos",
          "ai_extract": true
        },
        {
          "key": "title_html",
          "label": "Título principal (H1) — aceita HTML inline",
          "type": "html",
          "rows": 3,
          "help": "Pode usar <span class=\"highlight\">...</span> pra destacar palavras.",
          "ai_extract": true
        },
        {
          "key": "author.photo",
          "label": "Foto do autor",
          "type": "image_ai",
          "ai_prompt_key": "author_photo",
          "image_fname": "author",
          "ai_extract": false
        },
        {
          "key": "author.name",
          "label": "Nome do autor",
          "type": "text",
          "ai_extract": true
        },
        {
          "key": "author.date",
          "label": "Data",
          "type": "text",
          "placeholder": "Last Updated 10th Dec, 2025",
          "ai_extract": true
        },
        {
          "key": "summary_html",
          "label": "Resumo (parágrafo curto) — aceita HTML",
          "type": "html",
          "rows": 4,
          "help": "Use <span class=\"label\">Resumo</span>: ... <strong>...</strong>",
          "ai_extract": true
        }
      ]
    },
    {
      "key": "list_items",
      "label": "Itens da lista (numerados)",
      "type": "list",
      "min": 1,
      "max": 12,
      "recommended_count": [6, 10],
      "item_label_template": "Item {index}: {title_html}",
      "ai_extract": true,
      "fields": [
        {
          "key": "number",
          "label": "Número",
          "type": "text",
          "default_from_index": true,
          "ai_extract": true
        },
        {
          "key": "title_html",
          "label": "Título do item — aceita HTML",
          "type": "html",
          "rows": 2,
          "ai_extract": true
        },
        {
          "key": "image",
          "label": "Imagem do item",
          "type": "image_ai",
          "ai_prompt_key": "list_item_image",
          "image_fname_template": "list_item_{index_plus_1}",
          "ai_extract": false
        },
        {
          "key": "text_html",
          "label": "Texto descritivo — aceita HTML",
          "type": "html",
          "rows": 5,
          "ai_extract": true
        },
        {
          "key": "emoji_list",
          "label": "Bullets emoji (opcional)",
          "type": "string_list",
          "ai_extract": true,
          "help": "Lista de strings tipo \"🔥 Fat melting\"; deixe vazio se não tiver."
        }
      ]
    },
    {
      "key": "offer_1",
      "label": "Oferta 1 (após os itens)",
      "type": "group",
      "fields": [
        { "key": "title_html", "label": "Título — HTML", "type": "html", "rows": 2, "ai_extract": true },
        { "key": "title_red", "label": "Título em vermelho", "type": "boolean", "default": false, "ai_extract": false },
        { "key": "subtitle_html", "label": "Subtítulo — HTML (opcional)", "type": "html", "rows": 2, "ai_extract": true },
        { "key": "product_image", "label": "Foto do produto (você sobe)", "type": "image", "ai_extract": false },
        { "key": "stat_bar_top", "label": "Barra de estatística (topo)", "type": "text", "ai_extract": true },
        { "key": "stat_bar_bottom", "label": "Barra de estatística (fundo)", "type": "text", "ai_extract": true },
        { "key": "urgency_label", "label": "Label de urgência", "type": "text", "ai_extract": true },
        { "key": "urgency_title_html", "label": "Título de urgência — HTML", "type": "html", "rows": 2, "ai_extract": true },
        { "key": "price_old", "label": "Preço antigo", "type": "text", "ai_extract": true },
        { "key": "price_new", "label": "Preço novo", "type": "text", "ai_extract": true },
        { "key": "cta_text", "label": "Texto do botão", "type": "text", "ai_extract": true },
        { "key": "cta_href", "label": "URL do checkout", "type": "text", "ai_extract": false },
        { "key": "countdown_seconds", "label": "Countdown em segundos", "type": "number", "default": 900, "ai_extract": true },
        { "key": "stock_label", "label": "Label do estoque", "type": "text", "default": "BOTTLES REMAINING:", "ai_extract": true },
        { "key": "stock", "label": "Estoque restante", "type": "text", "ai_extract": true },
        { "key": "guarantee_text", "label": "Garantia", "type": "text", "ai_extract": true }
      ]
    },
    {
      "key": "timeline",
      "label": "Timeline de transformação",
      "type": "group",
      "fields": [
        { "key": "before_after_image", "label": "Imagem antes/depois", "type": "image_ai", "ai_prompt_key": "before_after_image", "image_fname": "timeline_before_after", "ai_extract": false },
        { "key": "title", "label": "Título da timeline", "type": "text", "ai_extract": true },
        { "key": "intro", "label": "Parágrafo de introdução", "type": "html", "rows": 3, "ai_extract": true },
        {
          "key": "steps",
          "label": "Etapas (3 etapas)",
          "type": "list",
          "min": 3,
          "max": 3,
          "ai_extract": true,
          "fields": [
            { "key": "badge", "label": "Badge (ex: Dias 1–3)", "type": "text", "ai_extract": true },
            { "key": "title", "label": "Título da etapa", "type": "text", "ai_extract": true },
            { "key": "checks", "label": "Bullets de checks", "type": "string_list", "ai_extract": true }
          ]
        },
        { "key": "cta_text", "label": "Texto do CTA", "type": "text", "ai_extract": true },
        { "key": "cta_href", "label": "URL do CTA", "type": "text", "ai_extract": false }
      ]
    },
    {
      "key": "reviews",
      "label": "Reviews / depoimentos",
      "type": "list",
      "min": 1,
      "max": 6,
      "recommended_count": [3, 4],
      "ai_extract": true,
      "fields": [
        { "key": "name", "label": "Nome", "type": "text", "ai_extract": true },
        { "key": "date", "label": "Data", "type": "text", "ai_extract": true },
        { "key": "stars", "label": "Estrelas", "type": "text", "default": "★★★★★", "ai_extract": false },
        { "key": "text", "label": "Texto do depoimento — aceita HTML", "type": "html", "rows": 3, "ai_extract": true },
        { "key": "photo", "label": "Foto", "type": "image_ai", "ai_prompt_key": "review_photo", "image_fname_template": "review_{index_plus_1}", "ai_extract": false }
      ]
    },
    {
      "key": "offer_2",
      "label": "Oferta 2 (last chance, no fim)",
      "type": "group",
      "fields": [
        { "key": "title_html", "label": "Título — HTML", "type": "html", "rows": 2, "ai_extract": true },
        { "key": "title_red", "label": "Título em vermelho", "type": "boolean", "default": true, "ai_extract": false },
        { "key": "subtitle_html", "label": "Subtítulo — HTML (opcional)", "type": "html", "rows": 2, "ai_extract": true },
        { "key": "product_image", "label": "Foto do produto (você sobe)", "type": "image", "ai_extract": false },
        { "key": "stat_bar_top", "label": "Barra de estatística (topo)", "type": "text", "ai_extract": true },
        { "key": "stat_bar_bottom", "label": "Barra de estatística (fundo)", "type": "text", "ai_extract": true },
        { "key": "urgency_label", "label": "Label de urgência", "type": "text", "ai_extract": true },
        { "key": "urgency_title_html", "label": "Título de urgência — HTML", "type": "html", "rows": 2, "ai_extract": true },
        { "key": "price_old", "label": "Preço antigo", "type": "text", "ai_extract": true },
        { "key": "price_new", "label": "Preço novo", "type": "text", "ai_extract": true },
        { "key": "cta_text", "label": "Texto do botão", "type": "text", "ai_extract": true },
        { "key": "cta_href", "label": "URL do checkout", "type": "text", "ai_extract": false },
        { "key": "countdown_seconds", "label": "Countdown em segundos", "type": "number", "default": 326, "ai_extract": true },
        { "key": "stock_label", "label": "Label do estoque", "type": "text", "default": "BOTTLES REMAINING:", "ai_extract": true },
        { "key": "stock", "label": "Estoque restante", "type": "text", "ai_extract": true },
        { "key": "guarantee_text", "label": "Garantia", "type": "text", "ai_extract": true }
      ]
    },
    {
      "key": "footer",
      "label": "Footer",
      "type": "group",
      "fields": [
        { "key": "logo", "label": "Logo da marca (PNG, você sobe — opcional)", "type": "image", "ai_extract": false },
        { "key": "copyright", "label": "Copyright", "type": "text", "ai_extract": true },
        { "key": "disclaimer", "label": "Disclaimer legal", "type": "html", "rows": 5, "ai_extract": true }
      ]
    }
  ]
}
